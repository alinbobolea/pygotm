# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*

# NetCDF / data
*.nc
# Vendored reference NetCDFs used by the in-tree test fixtures must be tracked.
!tests/fixtures/cases/**/*.nc
*.hdf5
gotm-model/
papers/

# Validation outputs and external reference data — anchored to repo root so it
# does not collide with the in-tree package directory src/pygotm/validation/.
# Keep only the curated docs report snapshot in git; NetCDFs, references, run
# directories, debug dumps, and the bulky per-variable JSON artifact stay local.
/validation/*
!/validation/report/
/validation/report/*
!/validation/report/*.html
!/validation/report/report.json

# Logs
*.log

# Sphinx documentation staging for validation HTML reports
docs/_validation_html/
docs/validation/cases/
docs/validation/_generated/

# Other
todo.md
.claude/
.codex/
.agents/
.planning/
